# Server-only: Prisma connection string for Supabase Postgres.
# For Vercel staging, use the pooled connection string from Supabase.
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1&schema=public"

# Public: canonical public URL used for QR labels and links.
# On Vercel, set this to your stable https://<project>.vercel.app URL.
# If omitted, Gear Locker falls back to the active request host or Vercel-provided host.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Public: Supabase browser/server client bootstrap values.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only: reserved for future storage/admin workflows.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Server-only in practice: reserved for future attachment upload flows.
SUPABASE_STORAGE_BUCKET="gear-locker"

# Optional staging gate for public tester access on Vercel.
STAGING_ACCESS_USERNAME="tester"
STAGING_ACCESS_PASSWORD="change-this-password"
