generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String   @id @default(cuid())
  workspaceId String?
  name      String   @unique
  slug      String   @unique
  prefix    String
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  items     Item[]
}

model Item {
  id               String             @id @default(cuid())
  workspaceId      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  assetId          String             @unique
  name             String
  categoryId       String?
  subcategory      String?
  brand            String?
  model            String?
  serialNumber     String?
  description      String?
  conditionGrade   ConditionGrade?
  conditionNotes   String?
  status           ItemStatus         @default(available)
  purchaseDate     DateTime?
  purchasePrice    Decimal?           @db.Decimal(10, 2)
  replacementValue Decimal?           @db.Decimal(10, 2)
  currency         String             @default("USD")
  purchaseSource   String?
  purchaseReference String?
  warrantyExpiresAt DateTime?
  locationId       String?
  notes            String?
  ownerName        String?
  qrCodeValue      String             @unique
  isConsumable     Boolean            @default(false)
  quantity         Int                @default(1)
  imageCoverUrl    String?
  workspace        Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  category         Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  location         Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  attachments      Attachment[]
  historyEvents    ItemHistoryEvent[]
  kits             ItemKit[]
  tags             ItemTag[]
  kitVerificationItems KitVerificationItem[]
  packageContents  ItemContent[]        @relation("ItemContents")
  checklistContents ItemChecklistContent[]
  containedIn      ItemContent[]        @relation("ItemContainedIn")

  @@index([status, createdAt])
  @@index([categoryId, status])
  @@index([locationId, status])
}

model Tag {
  id        String   @id @default(cuid())
  workspaceId String?
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  items     ItemTag[]
}

model ItemTag {
  itemId String
  tagId  String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

model Attachment {
  id              String                    @id @default(cuid())
  workspaceId     String?
  itemId          String
  type            AttachmentType
  title           String?
  fileName        String
  fileUrl         String
  storageProvider AttachmentStorageProvider @default(supabase)
  storageBucket   String?
  storagePath     String?
  fileSize        Int?
  mimeType        String?
  notes           String?
  createdAt       DateTime                  @default(now())
  workspace       Workspace?                @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  item            Item                      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, type])
}

model Kit {
  id                   String                  @id @default(cuid())
  workspaceId          String?
  name                 String
  assetId              String                  @unique
  code                 String?                 @unique
  description          String?
  status               KitStatus               @default(available)
  locationId           String?
  notes                String?
  qrCodeValue          String                  @unique
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  workspace            Workspace?              @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  location             Location?               @relation(fields: [locationId], references: [id], onDelete: SetNull)
  items                ItemKit[]
  historyEvents        KitHistoryEvent[]
  verificationSessions KitVerificationSession[]

  @@unique([name, locationId])
}

model ItemKit {
  itemId    String
  kitId     String
  quantity  Int      @default(1)
  notes     String?
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  kit       Kit      @relation(fields: [kitId], references: [id], onDelete: Cascade)

  @@id([itemId, kitId])
}

model ItemContent {
  parentItemId String
  childItemId  String
  quantity     Int      @default(1)
  notes        String?
  createdAt    DateTime @default(now())
  parentItem   Item     @relation("ItemContents", fields: [parentItemId], references: [id], onDelete: Cascade)
  childItem    Item     @relation("ItemContainedIn", fields: [childItemId], references: [id], onDelete: Cascade)

  @@id([parentItemId, childItemId])
}

model ItemChecklistContent {
  id           String   @id @default(cuid())
  parentItemId String
  label        String
  quantity     Int      @default(1)
  notes        String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  parentItem   Item     @relation(fields: [parentItemId], references: [id], onDelete: Cascade)

  @@index([parentItemId, sortOrder, createdAt])
}

model ItemHistoryEvent {
  id         String           @id @default(cuid())
  workspaceId String?
  itemId     String
  type       ItemHistoryType
  timestamp  DateTime         @default(now())
  summary    String
  details    String?
  note       String?
  statusFrom ItemStatus?
  statusTo   ItemStatus?
  locationId String?
  metadata   Json?
  workspace  Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  item       Item             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  location   Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([itemId, timestamp])
}

model KitHistoryEvent {
  id         String         @id @default(cuid())
  workspaceId String?
  kitId      String
  type       KitHistoryType
  timestamp  DateTime       @default(now())
  summary    String
  details    String?
  note       String?
  statusFrom KitStatus?
  statusTo   KitStatus?
  metadata   Json?
  workspace  Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  kit        Kit            @relation(fields: [kitId], references: [id], onDelete: Cascade)

  @@index([kitId, timestamp])
}

model KitVerificationSession {
  id          String                    @id @default(cuid())
  workspaceId String?
  kitId        String
  status       KitVerificationStatus    @default(in_progress)
  startedAt    DateTime                 @default(now())
  completedAt  DateTime?
  startedNote  String?
  completionNote String?
  workspace    Workspace?               @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  kit          Kit                      @relation(fields: [kitId], references: [id], onDelete: Cascade)
  items        KitVerificationItem[]
}

model KitVerificationItem {
  sessionId    String
  itemId       String
  expected     Boolean                  @default(true)
  verifiedAt   DateTime?
  isPresent    Boolean?
  note         String?
  session      KitVerificationSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item         Item                     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([sessionId, itemId])
}

model Location {
  id               String     @id @default(cuid())
  workspaceId      String?
  code             String?    @unique
  name             String
  description      String?
  parentLocationId String?
  sortOrder        Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  workspace        Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  parentLocation   Location?  @relation("LocationTree", fields: [parentLocationId], references: [id], onDelete: SetNull)
  childLocations   Location[] @relation("LocationTree")
  items            Item[]
  kits             Kit[]
  historyEvents    ItemHistoryEvent[]

  @@unique([name, parentLocationId])
}

model AppUser {
  id             String                @id @default(cuid())
  supabaseUserId String                @unique
  email          String?
  displayName    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  memberships    WorkspaceMembership[]
  workspacesOwned Workspace[]          @relation("WorkspaceOwner")
}

model Workspace {
  id               String                @id @default(cuid())
  name             String
  slug             String                @unique
  description      String?
  ownerId          String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  owner            AppUser?              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  memberships      WorkspaceMembership[]
  categories       Category[]
  tags             Tag[]
  items            Item[]
  attachments      Attachment[]
  kits             Kit[]
  locations        Location[]
  itemHistoryEvents ItemHistoryEvent[]
  kitHistoryEvents KitHistoryEvent[]
  verificationSessions KitVerificationSession[]
}

model WorkspaceMembership {
  workspaceId String
  userId      String
  role        WorkspaceRole          @default(owner)
  createdAt   DateTime               @default(now())
  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        AppUser                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

enum ConditionGrade {
  excellent
  good
  fair
  poor
  damaged
}

enum ItemStatus {
  available
  active
  in_repair
  missing
  stolen
  sold
  retired
}

enum KitStatus {
  available
  active
  incomplete
  retired
}

enum AttachmentType {
  photo
  receipt
  serial_photo
  manual
  warranty
  misc
}

enum AttachmentStorageProvider {
  supabase
  external
  local_placeholder
}

enum ItemHistoryType {
  created
  updated
  checked_in
  checked_out
  moved
  repair
  missing
  stolen
  sold
  note
}

enum KitHistoryType {
  created
  updated
  checked_out
  return_started
  return_completed
  incomplete
  note
}

enum KitVerificationStatus {
  in_progress
  completed
  incomplete
}

enum WorkspaceRole {
  owner
  admin
  member
  viewer
}
